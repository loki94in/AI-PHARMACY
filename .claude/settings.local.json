{
  "permissions": {
    "allow": [
      "Bash(dir C:\\\\Users\\\\ratna *)",
      "WebFetch(domain:gemini.google.com)",
      "Bash(dir *)",
      "Bash(npm list *)",
      "Bash(node *)",
      "Bash(mkdir -p ~/.ssh)",
      "Bash(chmod 700 ~/.ssh)",
      "Bash(ssh-keygen *)",
      "Bash(ssh-add *)",
      "Bash(ssh-agent bash *)",
      "Bash(ssh *)",
      "Bash(xxd)",
      "Bash(clip.exe)",
      "Bash(npx @anthropic-ai/mcpb pack)",
      "Bash(bash *)",
      "Bash(gzip *)",
      "Bash(ren *)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[System.Media.SystemSounds]::Exclamation.Play()\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[System.Media.SystemSounds]::Exclamation.Play()\""
          }
        ]
      }
    ]
  }
}
