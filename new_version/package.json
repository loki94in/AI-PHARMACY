{
  "name": "ai-pharmacy-v2",
  "version": "1.0.0",
  "description": "Windows-native AI Pharmacy System",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "test": "jest",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.aipharmacy.app",
    "productName": "AI Pharmacy",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
