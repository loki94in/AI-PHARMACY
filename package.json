{
  "name": "ai-pharmacy",
  "version": "0.1.0",
  "type": "module",
  "bin": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "enqueue-catalog": "tsx ./src/cli/enqueueCatalog.ts",
    "worker": "tsx ./src/worker/catalogWorker.ts",
    "watch-catalog": "tsx ./src/cli/watchCatalog.ts",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/PharmacyOS.exe"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.2",
    "express": "^5.2.1",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.4",
    "sqlite": "^5.0.2",
    "sqlite3": "^6.0.1",
    "unzipper": "^0.12.3",
    "whatsapp-web.js": "^1.22.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/sqlite3": "^3.1.11",
    "@types/unzipper": "^0.10.11",
    "jest": "^29.6.0",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.22.3"
  },
  "pkg": {
    "assets": [
      "data/**",
      "backup/**",
      "src/ui/**"
    ]
  }
}
